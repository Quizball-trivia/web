# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8001

# Canonical site URL — used for sitemap.xml, robots.txt, OpenGraph,
# and canonical link tags. In production set this to your real domain.
NEXT_PUBLIC_SITE_URL=https://quizball.io

# Feature flags
NEXT_PUBLIC_FEATURE_EVENTS_ENABLED=false

# Dev team allowlist (comma-separated emails). These accounts see the store UI
# as unlimited — buy buttons stay enabled, no "FULL"/"need more coins" states.
# Cosmetic only: the backend (DEV_UNLIMITED_EMAILS) is what actually bypasses
# the limits. Keep this list in sync with the backend var. Empty = disabled.
NEXT_PUBLIC_DEV_UNLIMITED_EMAILS=nikusha13.talakhadze@gmail.com,tsirgvaabrama@gmail.com,eloshaman@gmail.com,tazigrigolia@gmail.com

# Google Identity Services (GIS) — enables in-webview Google sign-in.
# This is the OAuth Web client_id from Google Cloud Console. Required to
# bypass `disallowed_useragent` 403 errors inside in-app browsers
# (Messenger, Instagram). Must have the deployed origin (e.g.
# https://quizball.io) listed under "Authorized JavaScript origins".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
